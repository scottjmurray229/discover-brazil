---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Brazilian History', url: '/history/' },
];

const pageTitle = 'Brazilian History — Indigenous Roots, Colonial Legacy & Modern Nation';
const pageDescription = 'From indigenous civilizations and Portuguese colonization to African heritage, independence, and modernist ambition — trace the history that shaped Brazil through the places where it happened.';

interface TimelineEvent {
  date: string;
  year: number;
  title: string;
  location: string;
  slug?: string | string[];
  description: string;
  whatToSee?: string;
  side: 'left' | 'right';
  era: 'indigenous' | 'colonial' | 'empire' | 'republic' | 'modern';
}

const timeline: TimelineEvent[] = [
  {
    date: 'Pre-1500',
    year: 1000,
    title: 'Indigenous Civilizations',
    location: 'Manaus, Bonito',
    slug: ['manaus', 'bonito'],
    description: 'Before European contact, Brazil was home to an estimated 5-10 million indigenous people from hundreds of distinct nations. The Tupi peoples dominated the coast, while the Amazon basin held complex societies that shaped the rainforest through agriculture and earthworks. Their legacy lives on in Brazilian language, food, and culture.',
    whatToSee: 'The MUSA (Museum of the Amazon) near Manaus, indigenous communities along the Rio Negro, and the Maracan\u00e3 rock art in Bonito\'s cave systems.',
    side: 'left',
    era: 'indigenous',
  },
  {
    date: '1500',
    year: 1500,
    title: 'Portuguese Arrival',
    location: 'Salvador, Recife',
    slug: ['salvador', 'recife'],
    description: 'Pedro \u00c1lvares Cabral landed on the Bahian coast in 1500, claiming Brazil for Portugal. Salvador became the first capital (1549), and the sugarcane economy transformed the Northeast. Recife and Olinda grew wealthy from sugar exports, and the Portuguese established a colonial system that would last over three centuries.',
    whatToSee: 'Salvador\'s Pel\u00f4urinho historic district (UNESCO), the churches of S\u00e3o Francisco and Bonfim, and Recife Antigo\'s colonial architecture.',
    side: 'right',
    era: 'colonial',
  },
  {
    date: '1550–1888',
    year: 1550,
    title: 'African Heritage & the Slave Trade',
    location: 'Salvador, Rio de Janeiro',
    slug: ['salvador', 'rio-de-janeiro'],
    description: 'Brazil received more enslaved Africans than any other country in the Americas — an estimated 4.9 million people. Their forced labor built the colonial economy, and their cultural traditions — capoeira, candombl\u00e9, samba, and Afro-Brazilian cuisine — became foundational to Brazilian identity. Slavery was abolished in 1888, the last country in the Western Hemisphere to do so.',
    whatToSee: 'The Afro-Brazilian Museum and capoeira schools in Salvador\'s Pel\u00f4urinho, the Valongo Wharf in Rio (UNESCO World Heritage Site), and the Terreiro de Jesus.',
    side: 'left',
    era: 'colonial',
  },
  {
    date: '1693–1800',
    year: 1693,
    title: 'The Gold Rush & Minas Gerais',
    location: 'Ouro Preto, Paraty',
    slug: ['ouro-preto', 'paraty'],
    description: 'The discovery of gold in Minas Gerais triggered a rush that transformed Brazil. Ouro Preto ("Black Gold") became one of the largest cities in the Americas. Gold flowed through Paraty\'s port to Lisbon. The wealth funded magnificent baroque churches and the artistic genius of Aleijadinho, Brazil\'s greatest colonial sculptor.',
    whatToSee: 'Ouro Preto\'s 13 baroque churches (UNESCO), the Inconfid\u00eancia Museum, Paraty\'s perfectly preserved colonial center, and the Gold Trail (Caminho do Ouro).',
    side: 'right',
    era: 'colonial',
  },
  {
    date: '1808–1822',
    year: 1808,
    title: 'The Portuguese Court & Independence',
    location: 'Rio de Janeiro, S\u00e3o Paulo',
    slug: ['rio-de-janeiro', 'sao-paulo'],
    description: 'Fleeing Napoleon, the Portuguese royal court relocated to Rio de Janeiro in 1808, making it the only European capital outside Europe. The city was transformed with libraries, gardens, and institutions. Independence came peacefully in 1822 when Prince Pedro declared "Independ\u00eancia ou Morte!" by the Ipiranga River in S\u00e3o Paulo.',
    whatToSee: 'The National Library and Imperial Palace in Rio, the Ipiranga Museum in S\u00e3o Paulo, and the Botanical Garden founded by the Portuguese court.',
    side: 'left',
    era: 'empire',
  },
  {
    date: '1889–1930',
    year: 1889,
    title: 'The Republic & Coffee Boom',
    location: 'S\u00e3o Paulo, Rio de Janeiro',
    slug: ['sao-paulo', 'rio-de-janeiro'],
    description: 'Brazil became a republic in 1889, and the coffee boom made S\u00e3o Paulo the economic powerhouse. European immigrants flooded in — Italians, Germans, Japanese — transforming Southern Brazil\'s culture. Rio remained the glamorous capital, gaining its iconic Copacabana promenade and modernizing with broad avenues.',
    whatToSee: 'S\u00e3o Paulo\'s Pinacoteca museum and Luz neighborhood, the Coffee Museum in Santos, and Rio\'s Confeitaria Colombo (1894).',
    side: 'right',
    era: 'republic',
  },
  {
    date: '1922–1960',
    year: 1922,
    title: 'Modernism & Bras\u00edlia',
    location: 'S\u00e3o Paulo, Bras\u00edlia',
    slug: ['sao-paulo', 'brasilia'],
    description: 'The Modern Art Week of 1922 in S\u00e3o Paulo launched a cultural revolution. Artists like Tarsila do Amaral and musicians like Villa-Lobos redefined Brazilian identity. The ultimate expression came in 1960 when President Kubitschek inaugurated Bras\u00edlia — a futuristic capital designed by Oscar Niemeyer and Lucio Costa, carved from the cerrado.',
    whatToSee: 'Bras\u00edlia\'s Cathedral, National Congress, and Itamaraty Palace (all UNESCO World Heritage). S\u00e3o Paulo\'s MASP museum and Ibirapuera Park pavilions.',
    side: 'left',
    era: 'republic',
  },
  {
    date: '1964–1985',
    year: 1964,
    title: 'Military Dictatorship',
    location: 'Rio de Janeiro, S\u00e3o Paulo, Bras\u00edlia',
    slug: ['rio-de-janeiro', 'sao-paulo', 'brasilia'],
    description: 'A military coup in 1964 began 21 years of authoritarian rule. Political opponents were persecuted, censorship was imposed, and the Amazon was opened for development through massive highway projects. Yet resistance grew through music (Tropicalia, MPB), theater, and journalism, laying the groundwork for redemocratization.',
    whatToSee: 'The Resist\u00eancia Memorial in S\u00e3o Paulo, the National Archive in Bras\u00edlia, and Rio\'s ABI (Brazilian Press Association) building where journalists fought censorship.',
    side: 'right',
    era: 'republic',
  },
  {
    date: '1985–Present',
    year: 1985,
    title: 'Redemocratization & Modern Brazil',
    location: 'All Destinations',
    slug: ['rio-de-janeiro', 'sao-paulo', 'salvador', 'brasilia', 'manaus'],
    description: 'Democracy returned in 1985, and the 1988 constitution established robust civil rights. Brazil hosted the 2014 World Cup and 2016 Olympics, showcasing its modern ambitions. The country continues to grapple with inequality, environmental challenges in the Amazon, and its complex racial heritage while celebrating the vibrant culture that makes it unique.',
    whatToSee: 'Rio\'s Olympic Boulevard and MAR museum, the ongoing Amazon conservation efforts near Manaus, Salvador\'s living Afro-Brazilian cultural scene, and S\u00e3o Paulo\'s street art on Batman Alley.',
    side: 'left',
    era: 'modern',
  },
];

const eraLabels: Record<string, { label: string; color: string }> = {
  indigenous: { label: 'Indigenous', color: '#065F46' },
  colonial: { label: 'Colonial Era', color: '#78350F' },
  empire: { label: 'Empire', color: '#6A1B9A' },
  republic: { label: 'Republic', color: '#1565C0' },
  modern: { label: 'Modern Era', color: '#0D7377' },
};
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="hist-hero">
    <video class="hist-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/history-hero.mp4" type="video/mp4" />
    </video>
    <div class="hist-hero-gradient"></div>
    <div class="hist-hero-noise"></div>
    <div class="hist-hero-content">
      <h1 class="hist-hero-title">Brazilian History</h1>
      <p class="hist-hero-subtitle">From indigenous civilizations and Portuguese colonization to African heritage, independence, and modernist ambition — trace the events that shaped Brazil through the places where they happened.</p>
      <div class="hist-hero-meta">
        <div class="hist-hero-meta-item">
          <span class="hist-hero-meta-label">Eras</span>
          <span class="hist-hero-meta-value">5</span>
        </div>
        <div class="hist-hero-meta-item">
          <span class="hist-hero-meta-label">Events</span>
          <span class="hist-hero-meta-value">9</span>
        </div>
        <div class="hist-hero-meta-item">
          <span class="hist-hero-meta-label">Destinations</span>
          <span class="hist-hero-meta-value">13</span>
        </div>
      </div>
    </div>
    <div class="hist-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="hist-personal reveal">
    <div class="container-content">
      <blockquote class="hist-personal-quote">
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Era Legend -->
  <section class="hist-legend reveal">
    <div class="container-content">
      <div class="hist-legend-bar">
        {Object.entries(eraLabels).map(([key, { label, color }]) => (
          <span class="hist-legend-chip" style={`--era-color: ${color};`}>{label}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="hist-timeline reveal">
    <div class="container-content">
      <div class="hist-timeline-line"></div>
      {timeline.map((event) => {
        const era = eraLabels[event.era];
        const slugs = Array.isArray(event.slug) ? event.slug : event.slug ? [event.slug] : [];
        return (
          <div class={`hist-event hist-event--${event.side}`} data-era={event.era}>
            <div class="hist-event-dot" style={`background: ${era.color};`}></div>
            <div class="hist-event-card">
              <div class="hist-event-era" style={`color: ${era.color};`}>{era.label}</div>
              <div class="hist-event-date">{event.date}</div>
              <h3 class="hist-event-title">{event.title}</h3>
              <p class="hist-event-location">{event.location}</p>
              <p class="hist-event-desc">{event.description}</p>
              {event.whatToSee && (
                <div class="hist-event-visit">
                  <span class="hist-event-visit-label">What to see today:</span>
                  <p class="hist-event-visit-text">{event.whatToSee}</p>
                </div>
              )}
              {slugs.length > 0 && (
                <div class="hist-event-links">
                  {slugs.slice(0, 3).map((s) => (
                    <a href={`/destinations/${s}/`} class="hist-event-link">Explore {s.charAt(0).toUpperCase() + s.slice(1)} &rarr;</a>
                  ))}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="hist-cta-section reveal">
    <div class="container-content">
      <div class="hist-cta-card">
        <h2 class="hist-cta-heading">Plan Your History Trip</h2>
        <p class="hist-cta-text">Tell our AI planner which historical periods interest you and it will build a multi-city itinerary connecting the key sites — from colonial churches to modernist masterpieces.</p>
        <a href="/plan/" class="hist-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What are the most important historical sites in Brazil?", answer: "Ouro Preto's baroque churches are UNESCO-listed masterpieces of colonial art. Salvador's Pelourinho district preserves the largest collection of colonial architecture in the Americas. Brasilia's modernist buildings by Oscar Niemeyer are a UNESCO World Heritage Site. Rio's Valongo Wharf is a powerful memorial to the Atlantic slave trade. The Amazon region holds archaeological sites revealing pre-Columbian civilizations." },
    { question: "How did slavery shape Brazil?", answer: "Brazil imported more enslaved Africans than any other country — an estimated 4.9 million people over three centuries. Their forced labor built the colonial economy based on sugar, gold, and coffee. But enslaved Africans and their descendants also created the foundations of Brazilian culture: samba, capoeira, candomble, and much of the cuisine. Understanding this history is essential context for travel, especially in Salvador and Rio." },
    { question: "What is the significance of Brasilia?", answer: "Brasilia was built from scratch in just 41 months (1956-1960) to move the capital from Rio de Janeiro to the interior. Designed by architect Oscar Niemeyer and urban planner Lucio Costa, it's a bold modernist vision shaped like an airplane from above. The Cathedral, National Congress, and Itamaraty Palace are architectural landmarks. It was designated a UNESCO World Heritage Site in 1987." },
    { question: "How do indigenous cultures persist in modern Brazil?", answer: "Brazil has over 300 indigenous groups speaking 274 languages. Many communities in the Amazon maintain traditional ways of life while navigating modern challenges. In cities, indigenous influences are visible in place names (Ipanema, Guanabara, Tijuca), foods (mandioca, acai, guarana), and cultural practices. The MUSA museum near Manaus and indigenous community visits offer respectful ways to learn about these living cultures." },
    { question: "What was the military dictatorship period like?", answer: "From 1964 to 1985, Brazil was under military rule. The regime censored the press, persecuted political opponents, and pursued massive infrastructure projects including Amazon highways. Cultural resistance came through music — Tropicalia, MPB (Brazilian Popular Music), and artists like Caetano Veloso and Chico Buarque used coded lyrics to protest. The Memorial da Resistencia in Sao Paulo documents this period." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Brazilian History Guide"
      description="A timeline PDF covering the key events, peoples, and sites that shaped Brazil — with visitor tips for every historical destination."
      bullets={[
        'Complete timeline from indigenous civilizations to modern Brazil',
        'Must-visit museums, churches, and memorials in each city',
        'Colonial architecture and modernist landmarks worth seeing',
        'Recommended history books and documentaries for pre-trip reading',
      ]}
      guideTag="pillar-history"
    />
  </div>

  <!-- Cross-links -->
  <section class="hist-crosslinks reveal">
    <div class="container-content">
      <h3 class="hist-crosslinks-heading">Explore More</h3>
      <div class="hist-crosslinks-grid">
        <a href="/cuisine/" class="hist-crosslink-card">
          <span class="hist-crosslink-icon">&#127860;</span>
          <span class="hist-crosslink-label">Food & Cuisine</span>
          <span class="hist-crosslink-desc">18 dishes across 4 regions with where to find the best version</span>
        </a>
        <a href="/hiking/" class="hist-crosslink-card">
          <span class="hist-crosslink-icon">&#9968;</span>
          <span class="hist-crosslink-label">Outdoor Activities</span>
          <span class="hist-crosslink-desc">Amazon trekking, Chapada Diamantina, Iguazu trails, and more</span>
        </a>
        <a href="/practical/" class="hist-crosslink-card">
          <span class="hist-crosslink-icon">&#128218;</span>
          <span class="hist-crosslink-label">Practical Guide</span>
          <span class="hist-crosslink-desc">Visas, currency, trains, budget tips, and safety info</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* HERO */
  .hist-hero { position: relative; min-height: 60vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 5rem var(--space-6) 60px; overflow: hidden; }
  .hist-hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .hist-hero-gradient { position: absolute; inset: 0; z-index: 1; background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%); }
  .hist-hero-noise { position: absolute; inset: 0; z-index: 2; background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events: none; }
  .hist-hero-content { position: relative; z-index: 3; max-width: 720px; }
  .hist-hero-title { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: var(--weight-bold); color: #fff; line-height: 1.1; margin: 0 0 var(--space-3); }
  .hist-hero-subtitle { font-size: clamp(1rem, 2vw, 1.15rem); color: rgba(255,255,255,0.85); line-height: 1.6; margin: 0 0 var(--space-5); max-width: 580px; }
  .hist-hero-meta { display: flex; gap: var(--space-5); flex-wrap: wrap; }
  .hist-hero-meta-item { display: flex; flex-direction: column; gap: 2px; }
  .hist-hero-meta-label { font-size: 0.65rem; font-weight: var(--weight-semibold); text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.5); }
  .hist-hero-meta-value { font-size: 1.1rem; font-weight: var(--weight-bold); color: #fff; }
  .hist-scroll-hint { position: absolute; bottom: 16px; right: var(--space-6); z-index: 3; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(255,255,255,0.35); text-align: center; animation: histBounce 2s ease-in-out infinite; }
  @keyframes histBounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(6px); } }

  /* PERSONAL */
  .hist-personal { padding-block: var(--space-8); }
  .hist-personal-quote { max-width: 680px; margin: 0 auto; padding: var(--space-6) var(--space-8); border-left: 4px solid var(--color-warm-coral); background: var(--color-sky); border-radius: 0 12px 12px 0; }
  .hist-personal-quote cite { font-size: var(--text-caption); color: var(--color-warm-coral); font-weight: var(--weight-semibold); font-style: normal; }

  /* ERA LEGEND */
  .hist-legend { padding: 0 0 var(--space-6); }
  .hist-legend-bar { display: flex; justify-content: center; gap: var(--space-2); flex-wrap: wrap; }
  .hist-legend-chip { display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; font-weight: var(--weight-semibold); padding: 6px 14px; border-radius: 20px; color: var(--era-color); background: color-mix(in srgb, var(--era-color) 10%, transparent); }
  .hist-legend-chip::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--era-color); }

  /* TIMELINE */
  .hist-timeline { position: relative; padding: var(--space-8) 0 var(--space-12); }
  .hist-timeline .container-content { position: relative; }
  .hist-timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 3px; background: linear-gradient(to bottom, #78350F, #6A1B9A, #C62828, #1565C0, #0D7377); transform: translateX(-50%); border-radius: 2px; }
  .hist-event { position: relative; display: flex; width: 100%; margin-bottom: var(--space-8); }
  .hist-event--left { justify-content: flex-start; padding-right: calc(50% + 24px); }
  .hist-event--right { justify-content: flex-end; padding-left: calc(50% + 24px); }
  .hist-event-dot { position: absolute; left: 50%; top: 24px; width: 16px; height: 16px; border-radius: 50%; border: 3px solid var(--color-white); box-shadow: 0 2px 8px rgba(0,0,0,0.15); transform: translateX(-50%); z-index: 1; }
  .hist-event-card { background: var(--color-white); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: var(--space-5); max-width: 480px; transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .hist-event-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
  .hist-event-era { font-size: 0.65rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
  .hist-event-date { font-size: 0.78rem; font-weight: var(--weight-semibold); color: var(--color-slate); margin-bottom: var(--space-1); }
  .hist-event-title { font-size: 1.1rem; font-weight: var(--weight-bold); color: var(--color-deep-night); margin: 0 0 var(--space-1); line-height: 1.3; }
  .hist-event-location { font-size: 0.78rem; color: var(--color-ocean-teal); font-weight: var(--weight-medium); margin: 0 0 var(--space-3); }
  .hist-event-desc { font-size: 0.85rem; color: var(--color-slate); line-height: 1.65; margin: 0 0 var(--space-3); }
  .hist-event-visit { background: var(--color-sky); border-radius: 10px; padding: var(--space-3); margin-bottom: var(--space-3); }
  .hist-event-visit-label { font-size: 0.7rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ocean-teal); }
  .hist-event-visit-text { font-size: 0.8rem; color: var(--color-slate); line-height: 1.5; margin: 4px 0 0; }
  .hist-event-links { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .hist-event-link { font-size: 0.72rem; font-weight: var(--weight-semibold); color: var(--color-ocean-teal); text-decoration: none; padding: 4px 12px; border: 1px solid var(--color-ocean-teal); border-radius: 20px; transition: all 0.2s ease; }
  .hist-event-link:hover { background: var(--color-ocean-teal); color: #fff; }

  /* CTA */
  .hist-cta-section { padding: var(--space-6) 0 var(--space-8); }
  .hist-cta-card { background: linear-gradient(135deg, var(--color-deep-night) 0%, #2D3748 100%); border-radius: 20px; padding: var(--space-8) var(--space-6); text-align: center; color: #fff; }
  .hist-cta-heading { font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: var(--weight-bold); margin: 0 0 var(--space-3); color: #fff; }
  .hist-cta-text { font-size: 1rem; color: rgba(255,255,255,0.75); max-width: 520px; margin: 0 auto var(--space-5); line-height: 1.6; }
  .hist-cta-button { display: inline-block; background: var(--color-warm-coral); color: #fff; font-size: 0.9rem; font-weight: var(--weight-semibold); padding: 12px 28px; border-radius: 40px; text-decoration: none; transition: background 0.2s ease, transform 0.2s ease; }
  .hist-cta-button:hover { background: #d4553b; transform: translateY(-2px); }

  /* CROSS-LINKS */
  .hist-crosslinks { padding: 0 0 var(--space-10); }
  .hist-crosslinks-heading { font-size: 1.1rem; font-weight: var(--weight-bold); color: var(--color-deep-night); text-align: center; margin: 0 0 var(--space-4); }
  .hist-crosslinks-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-4); max-width: 800px; margin: 0 auto; }
  .hist-crosslink-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); padding: var(--space-5) var(--space-4); background: var(--color-white); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; text-decoration: none; color: inherit; text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .hist-crosslink-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .hist-crosslink-icon { font-size: 1.8rem; }
  .hist-crosslink-label { font-size: 0.95rem; font-weight: var(--weight-bold); color: var(--color-deep-night); }
  .hist-crosslink-desc { font-size: 0.78rem; color: var(--color-slate); line-height: 1.4; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hist-timeline-line { left: 20px; }
    .hist-event--left, .hist-event--right { padding-left: 48px; padding-right: 0; justify-content: flex-start; }
