---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Brazilian Cuisine Guide', url: '/cuisine/' },
];

const pageTitle = 'Brazilian Cuisine Guide — Eat Your Way Across Brazil';
const pageDescription = 'A region-by-region menu of the dishes that define Brazilian food culture — from feijoada and churrasco to moqueca, acai bowls, and brigadeiro.';

interface Dish {
  name: string;
  image?: string;
  destination: string;
  slug: string;
  price: string;
  description: string;
  tag?: string;
}

interface MenuSection {
  region: string;
  tagline: string;
  gradient: string;
  dishes: Dish[];
}

const menu: MenuSection[] = [
  {
    region: 'Southeast',
    tagline: 'Feijoada, churrasco, street-side pasteis, and the world\'s best coffee culture',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
    dishes: [
      {
        name: 'Feijoada',
        destination: 'Rio de Janeiro',
        slug: 'rio-de-janeiro',
        price: 'R$40–80 / $8–16 USD',
        description: 'Brazil\'s national dish — a rich black bean stew with pork ribs, sausage, and dried beef, served with rice, farofa, collard greens, and orange slices. Traditionally a Saturday lunch ritual in Rio\'s botequims.',
        tag: 'Iconic',
      },
      {
        name: 'Pastel de Feira',
        destination: 'S\u00e3o Paulo',
        slug: 'sao-paulo',
        price: 'R$8–15 / $2–3 USD',
        description: 'Crispy deep-fried pastry pockets filled with ground meat, cheese, heart of palm, or shrimp. Found at every street market (feira) in S\u00e3o Paulo. Best eaten hot with a cold sugarcane juice.',
        tag: 'Must-Try',
      },
      {
        name: 'P\u00e3o de Queijo',
        destination: 'Ouro Preto',
        slug: 'ouro-preto',
        price: 'R$5–10 / $1–2 USD',
        description: 'Chewy cheese bread balls made from tapioca flour and Minas cheese — a Minas Gerais staple that\'s become Brazil\'s most beloved snack. Best warm from a padaria with strong caf\u00e9.',
        tag: 'Heritage',
      },
      {
        name: 'Caipirinha',
        destination: 'Rio de Janeiro',
        slug: 'rio-de-janeiro',
        price: 'R$15–30 / $3–6 USD',
        description: 'Brazil\'s signature cocktail — muddled lime, sugar, and cacha\u00e7a (sugarcane spirit) over ice. Simple, refreshing, and dangerously drinkable. Try variations with passion fruit, kiwi, or strawberry.',
        tag: 'Iconic',
      },
      {
        name: 'Coxinha',
        destination: 'S\u00e3o Paulo',
        slug: 'sao-paulo',
        price: 'R$6–12 / $1–2 USD',
        description: 'Teardrop-shaped croquette filled with shredded chicken in a creamy catupiry sauce, breaded and fried. S\u00e3o Paulo\'s favorite bar snack and the king of Brazilian street food.',
        tag: 'Must-Try',
      },
      {
        name: 'Peixe na Telha',
        destination: 'Paraty',
        slug: 'paraty',
        price: 'R$60–100 / $12–20 USD',
        description: 'Fresh fish baked on a clay tile with tomatoes, onions, peppers, and coconut milk. A coastal specialty of Paraty\'s waterfront restaurants — best with a cold chopp (draft beer).',
      },
    ],
  },
  {
    region: 'Northeast',
    tagline: 'Afro-Brazilian flavors, dend\u00ea oil, tropical fruits, and the soul of Brazilian cooking',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
    dishes: [
      {
        name: 'Acaraj\u00e9',
        destination: 'Salvador',
        slug: 'salvador',
        price: 'R$10–20 / $2–4 USD',
        description: 'Black-eyed pea fritters deep-fried in dend\u00ea (palm) oil, split open and stuffed with vatap\u00e1 (shrimp paste), caruru, and dried shrimp. Salvador\'s iconic street food with deep African roots — find the baianas in white on every corner.',
        tag: 'Iconic',
      },
      {
        name: 'Moqueca Baiana',
        destination: 'Salvador',
        slug: 'salvador',
        price: 'R$60–120 / $12–24 USD',
        description: 'Rich seafood stew with fish, shrimp, or crab cooked in coconut milk, dend\u00ea oil, tomatoes, and peppers. Served bubbling in a clay pot with rice and pir\u00e3o (fish meal porridge). The crown jewel of Bahian cuisine.',
        tag: 'Must-Try',
      },
      {
        name: 'Tapioca Crepe',
        destination: 'Recife',
        slug: 'recife',
        price: 'R$8–18 / $2–4 USD',
        description: 'Gluten-free crepe made from hydrated tapioca starch, filled with coalho cheese, coconut, condensed milk, or savory options like sun-dried beef (carne de sol). A northeastern breakfast staple.',
        tag: 'Heritage',
      },
      {
        name: 'Bolo de Rolo',
        destination: 'Recife',
        slug: 'recife',
        price: 'R$15–30 / $3–6 USD per slice',
        description: 'Recife\'s signature spiral cake — paper-thin layers of sponge rolled with guava paste. A masterpiece of patience and technique, this Pernambuco delicacy is Brazil\'s answer to the Hungarian k\u00fcrt\u0151skalacs.',
      },
      {
        name: 'Lagosta Grelhada',
        destination: 'Jericoacoara',
        slug: 'jericoacoara',
        price: 'R$80–150 / $16–30 USD',
        description: 'Grilled spiny lobster served with garlic butter, rice, and farofa on the beach. Jericoacoara and the Cear\u00e1 coast offer some of the freshest and most affordable lobster in the world.',
        tag: 'Must-Try',
      },
      {
        name: 'Peixe Fresco',
        destination: 'Fernando de Noronha',
        slug: 'fernando-de-noronha',
        price: 'R$70–140 / $14–28 USD',
        description: 'Freshly caught fish grilled or pan-fried, served with tropical fruit salsas. Fernando de Noronha\'s island restaurants serve the day\'s catch in unforgettable ocean-view settings.',
      },
    ],
  },
  {
    region: 'South & Central-North',
    tagline: 'Churrasco traditions, A\u00e7a\u00ed bowls, Amazonian ingredients, and the frontier of Brazilian flavor',
    gradient: 'linear-gradient(135deg, #1A2332 0%, #6A1B9A 50%, #D4A853 100%)',
    dishes: [
      {
        name: 'Churrasco',
        destination: 'Florian\u00f3polis',
        slug: 'florianopolis',
        price: 'R$60–120 / $12–24 USD',
        description: 'Brazilian barbecue at its finest — picanha (top sirloin cap), costela (ribs), and linguica grilled over charcoal and carved tableside. The ga\u00facho tradition from southern Brazil is a meat lover\'s paradise.',
        tag: 'Iconic',
      },
      {
        name: 'Sequencia de Ostras',
        destination: 'Florian\u00f3polis',
        slug: 'florianopolis',
        price: 'R$40–80 / $8–16 USD',
        description: 'Florian\u00f3polis produces 95% of Brazil\'s oysters. Order a sequencia (tasting platter) with natural, grilled, and gratineed oysters at the oyster farms of Ribeir\u00e3o da Ilha.',
        tag: 'Must-Try',
      },
      {
        name: 'Peixe na Folha de Bananeira',
        destination: 'Bonito',
        slug: 'bonito',
        price: 'R$50–90 / $10–18 USD',
        description: 'Fish wrapped in banana leaf and slow-grilled — a Pantanal and Mato Grosso do Sul tradition. Bonito restaurants use locally caught pintado and pacu from the crystal-clear rivers.',
        tag: 'Heritage',
      },
      {
        name: 'A\u00e7a\u00ed na Tigela',
        destination: 'Manaus',
        slug: 'manaus',
        price: 'R$12–25 / $2–5 USD',
        description: 'Thick frozen a\u00e7a\u00ed berry pur\u00e9e served in a bowl with granola, banana, and honey. In the Amazon, a\u00e7a\u00ed is eaten as a savory side with fish and farinha — the authentic way.',
        tag: 'Iconic',
      },
      {
        name: 'Tucupi com Pato',
        destination: 'Manaus',
        slug: 'manaus',
        price: 'R$50–90 / $10–18 USD',
        description: 'Duck braised in tucupi (fermented manioc broth) with jambu leaves that make your lips tingle. A unique Amazonian dish you won\'t find anywhere else in Brazil — deeply aromatic and unforgettable.',
        tag: 'Heritage',
      },
      {
        name: 'Brigadeiro',
        destination: 'Bras\u00edlia',
        slug: 'brasilia',
        price: 'R$3–8 / $1–2 USD',
        description: 'Chocolate truffles made from condensed milk, cocoa powder, and butter, rolled in chocolate sprinkles. Brazil\'s most famous sweet — found at every birthday party, bakery, and dessert shop in the country.',
        tag: 'Must-Try',
      },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <video class="menu-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/cuisine-hero.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">The Brazilian Menu</h1>
      <p class="menu-hero-subtitle">Feijoada, churrasco, acaraj\u00e9, moqueca, a\u00e7a\u00ed bowls — eat your way across four regions and discover the dishes that define each destination.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Dishes</span>
          <span class="menu-hero-meta-value">18</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Regions</span>
          <span class="menu-hero-meta-value">4</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Destinations</span>
          <span class="menu-hero-meta-value">13</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Menu Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">Think of this as your tasting menu for Brazil. We've organized the country's essential dishes by region — the <strong>Southeast</strong> with feijoada and coxinhas, the <strong>Northeast</strong> with moqueca and acaraj\u00e9, and the <strong>South &amp; Central-North</strong> with churrasco and Amazonian flavors. Click any dish to explore the destination where it's famous.</p>
        <div class="menu-intro-legend">
          <span class="menu-tag menu-tag--heritage">Heritage</span>
          <span class="menu-tag menu-tag--musttry">Must-Try</span>
          <span class="menu-tag menu-tag--iconic">Iconic</span>
          <span class="menu-tag menu-tag--fresh">Fresh Catch</span>
          <span class="menu-tag menu-tag--rare">Rare</span>
          <span class="menu-tag menu-tag--pasalubong">Pasalubong</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Sections by Region -->
  {menu.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.region}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.dishes.length} dishes</span>
          </div>
          <div class="menu-region-ornament">&#9733;</div>
        </div>

        <div class="menu-dish-grid">
          {section.dishes.map((dish) => (
            <a href={`/destinations/${dish.slug}/`} class="menu-dish-card">
              <div class="menu-dish-media" style={`background: ${section.gradient};`}>
                {dish.image && (
                  <img src={dish.image} alt={`${dish.name} — ${dish.destination}`} class="menu-dish-img" loading="lazy" />
                )}
                {dish.tag && (
                  <span class={`menu-tag menu-tag--${dish.tag.toLowerCase().replace(/[^a-z]/g, '')}`}>{dish.tag}</span>
                )}
              </div>
              <div class="menu-dish-body">
                <div class="menu-dish-top">
                  <h3 class="menu-dish-name">{dish.name}</h3>
                  <span class="menu-dish-price">{dish.price}</span>
                </div>
                <p class="menu-dish-destination">{dish.destination}</p>
                <p class="menu-dish-desc">{dish.description}</p>
                <span class="menu-dish-cta">Explore {dish.destination} &rarr;</span>
              </div>
              <div class="menu-dish-overlay">
                <p class="menu-dish-overlay-desc">{dish.description}</p>
                <span class="menu-dish-overlay-cta">Explore {dish.destination} &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="menu-cta-section reveal">
    <div class="container-content">
      <div class="menu-cta-card">
        <h2 class="menu-cta-heading">Plan Your Food Trip</h2>
        <p class="menu-cta-text">Tell our AI planner which cuisines you want to try and it will build a multi-city itinerary — with the best restaurants, markets, and food experiences across Brazil.</p>
        <a href="/plan/" class="menu-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What are the must-try foods in Brazil?", answer: "Every region has signature dishes. Southeast: feijoada (black bean stew), coxinha, and p\u00e3o de queijo. Northeast: acaraj\u00e9, moqueca baiana, and tapioca crepes. South: churrasco (barbecue) and barreado. Amazon: tucupi com pato and a\u00e7a\u00ed served savory with fish. The common thread: generous portions, bold flavors, and prices that make you want to eat out three times a day." },
    { question: "Is Brazilian food vegetarian-friendly?", answer: "Traditional Brazilian cuisine is heavily meat-based, but options are growing. P\u00e3o de queijo, tapioca crepes, a\u00e7a\u00ed bowls, and aipim frito (fried cassava) are naturally vegetarian. S\u00e3o Paulo has one of the best vegetarian restaurant scenes in South America. In smaller towns, look for 'sem carne' (without meat) options. Buffet-by-weight restaurants (comida a quilo) always have salads and vegetable sides." },
    { question: "How much does food cost in Brazil?", answer: "Brazil is very affordable for eating out. Street food: R$5-20 (~$1-4 USD). Comida a quilo (buffet by weight): R$25-50 (~$5-10 USD) for a full meal. Mid-range restaurants: R$50-120 (~$10-24 USD). Fine dining: R$150-400 (~$30-80 USD). A daily food budget of R$80-150 covers three meals comfortably. Fernando de Noronha is the most expensive; Salvador, Recife, and Manaus offer the best value." },
    { question: "What should I drink in Brazil?", answer: "Caipirinha (cacha\u00e7a, lime, sugar) is the national cocktail — try it with different fruits. Brazilian craft beer is booming, especially in S\u00e3o Paulo and Florian\u00f3polis. Fresh tropical juices (suco natural) are available everywhere — try cupua\u00e7u, graviola, and caju. Coffee culture runs deep — order a cafezinho (strong espresso) at any bakery. In the Amazon, try guarana from the fruit, not the soda." },
    { question: "Are there food markets worth visiting?", answer: "S\u00e3o Paulo's Mercado Municipal is iconic — try the mortadella sandwich and pasteis. In Salvador, visit Mercado Modelo for Bahian street food. Bel\u00e9m's Ver-o-Peso market is the best in the Amazon for exotic fruits and fish. Rio's Feira de S\u00e3o Crist\u00f3v\u00e3o is a massive northeastern food and culture fair. Every city has weekly street fairs (feiras) worth a morning visit." },
    { question: "What are the best food tours in Brazil?", answer: "Rio, Salvador, and S\u00e3o Paulo have the best food tour scenes. In Rio, try a botequim crawl through Lapa or a favela food tour. In Salvador, a Bahian cooking class teaches moqueca and acaraj\u00e9. In S\u00e3o Paulo, explore the Liberdade Japanese quarter or Vila Madalena\'s bar food. Most tours run R$150-300 per person and include enough food to replace a full meal." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Brazilian Food Guide"
      description="A region-by-region PDF guide to Brazilian cuisine — with the best restaurants, markets, and dishes you can't miss."
      bullets={[
        'All 18 dishes with where to find the best version',
        'Price guide — from R$5 street food to R$120 restaurant meals',
        'Vegetarian options and dietary tips by region',
        'Best food markets and food tour recommendations',
      ]}
      guideTag="pillar-cuisine"
    />
  </div>

  <!-- Cross-links -->
  <section class="menu-crosslinks reveal">
    <div class="container-content">
      <h3 class="menu-crosslinks-heading">Explore More</h3>
      <div class="menu-crosslinks-grid">
        <a href="/history/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127963;</span>
          <span class="menu-crosslink-label">History Guide</span>
          <span class="menu-crosslink-desc">From indigenous peoples to independence and modernism</span>
        </a>
        <a href="/hiking/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#9968;</span>
          <span class="menu-crosslink-label">Outdoor Activities</span>
          <span class="menu-crosslink-desc">Amazon trekking, Chapada Diamantina, Iguazu trails, and more</span>
        </a>
        <a href="/destinations/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127965;</span>
          <span class="menu-crosslink-label">All Destinations</span>
          <span class="menu-crosslink-desc">13 destinations across 4 regions with honest reviews</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Warm, food-inspired gradient
     ================================================================ */
  .menu-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .menu-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .menu-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
  }

  .menu-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .menu-hero-content {
    position: relative;
    z-index: 3;
    max-width: 720px;
  }

  .menu-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .menu-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    max-width: 580px;
  }

  .menu-hero-meta {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .menu-hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .menu-hero-meta-label {
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
  }

  .menu-hero-meta-value {
    font-size: 1.1rem;
    font-weight: var(--weight-bold);
    color: #fff;
  }

  .menu-scroll-hint {
    position: absolute;
    bottom: 16px;
    right: var(--space-6);
    z-index: 3;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    animation: menuBounce 2s ease-in-out infinite;
  }

  @keyframes menuBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ================================================================
     MENU INTRO
     ================================================================ */
  .menu-intro {
    padding: var(--space-8) 0 var(--space-4);
  }

  .menu-intro-card {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: var(--space-5) var(--space-6);
    text-align: center;
  }

  .menu-intro-text {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto var(--space-4);
  }

  .menu-intro-legend {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ================================================================
     TAGS
     ================================================================ */
  .menu-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1.4;
  }

  .menu-tag--heritage {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  .menu-tag--musttry, .menu-tag--mustry {
    background: rgba(13, 115, 119, 0.1);
    color: var(--color-ocean-teal);
  }

  .menu-tag--iconic {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--freshcatch {
    background: rgba(33, 150, 243, 0.1);
    color: #1565C0;
  }

  .menu-tag--rare {
    background: rgba(106, 27, 154, 0.1);
    color: #6A1B9A;
  }

  .menu-tag--pasalubong {
    background: rgba(232, 101, 74, 0.1);
    color: var(--color-warm-coral);
  }

  .menu-tag--legendary {
    background: rgba(212, 168, 83, 0.15);
    color: #9A7B2E;
  }

  .menu-tag--nationaldish {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  /* ================================================================
     REGION SECTION
     ================================================================ */
  .menu-region {
    padding: var(--space-6) 0;
  }

  .menu-region-header {
    position: relative;
    border-radius: 20px;
    padding: var(--space-6) var(--space-6);
